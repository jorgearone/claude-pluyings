# Obtén tu API key en: https://app.fireworks.ai/
#
# OPCIÓN A — Variable de entorno (Linux/macOS/Windows sin sandbox)
# Agrega a ~/.bashrc, ~/.zshrc o al perfil de PowerShell:
#   export FIREWORKS_API_KEY=tu_api_key_aqui
#
# OPCIÓN B — Archivo de configuración (recomendado para Claude Desktop desde Microsoft Store)
# El sandbox de la Store no hereda variables del sistema. Crea el archivo:
#
#   Windows (ruta dentro del sandbox):
#     %APPDATA%\Claude\plugins.env
#   Ruta física real:
#     C:\Users\<usuario>\AppData\Local\Packages\Claude_pzs8sxrjxfjjc\LocalCache\Roaming\Claude\plugins.env
#
#   Linux/macOS:
#     ~/.config/claude/plugins.env
#
# El skill leerá automáticamente desde ese archivo si la variable de entorno está vacía.

FIREWORKS_API_KEY=tu_api_key_aqui
